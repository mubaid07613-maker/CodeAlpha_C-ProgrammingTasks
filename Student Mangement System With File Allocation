#include <stdio.h>
#include <string.h>
#include <stdlib.h>

#define MAX 100   // Maximum number of students allowed

// Structure to store student information
struct Student
{
    char name[50];
    int rollNo;
    float gpa;
};

// Global variables
struct Student students[MAX];
int count = 0; // Starts at 0 since data will load from the CSV file
char filePath[256]; // Stores the user's local file path

// Function declarations
void header();
void displayStudents();
void addStudent();
int searchStudent(int rollNo);
int loadFromFile();
void saveToFile();

int main()
{
    int choice;
    int rollNo;
    int index;

    // File selection system at startup
    printf("=====================================\n");
    printf("     FILE SELECTION SYSTEM           \n");
    printf("=====================================\n");
    printf("Enter the local CSV file path: ");
    scanf(" %255[^\n]", filePath);

    // Attempt to load data from the user's file
    if (!loadFromFile()) 
    {
        printf("Starting program with an empty database.\n");
    }

    header();

    // Menu loop
    do
    {
        printf("\n==============================\n");
        printf(" STUDENT MANAGEMENT SYSTEM\n");
        printf("==============================\n");

        printf("1. Display Students\n");
        printf("2. Add Student\n");
        printf("3. Search Student\n");
        printf("4. Exit\n");

        printf("\nEnter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                displayStudents();
                header();
                break;

            case 2:
                addStudent();
                header();
                break;

            case 3:
                printf("Enter roll number to search: ");
                scanf("%d", &rollNo);

                index = searchStudent(rollNo);

                if(index == -1)
                {
                    printf("Student not found.\n");
                }
                else
                {
                    printf("\nStudent Found:\n");
                    printf("Name    : %s\n", students[index].name);
                    printf("Roll No : %d\n", students[index].rollNo);
                    printf("GPA     : %.2f\n", students[index].gpa);
                }
                header();
                break;

            case 4:
                printf("Exiting program...\n");
                break;

            default:
                printf("Invalid choice. Please try again.\n");
        }

    } while(choice != 4);

    return 0;
}

// Function to display all students
void displayStudents()
{
    int i;

    if(count == 0)
    {
        printf("No student records available.\n");
        return;
    }

    printf("\n========== STUDENT RECORDS ==========\n");

    for(i = 0; i < count; i++)
    {
        printf("\nStudent %d\n", i + 1);
        printf("Name    : %s\n", students[i].name);
        printf("Roll No : %d\n", students[i].rollNo);
        printf("GPA     : %.2f\n", students[i].gpa);
    }
}

// Function to add a new student
void addStudent()
{
    int rollNo;
    int index;

    if(count >= MAX)
    {
        printf("Student storage is full.\n");
        return;
    }

    printf("\nEnter student name: ");
    scanf(" %49[^\n]", students[count].name);

    printf("Enter roll number: ");
    scanf("%d", &rollNo);

    index = searchStudent(rollNo);

    if(index != -1)
    {
        printf("Roll number already exists.\n");
        return;
    }

    students[count].rollNo = rollNo;

    printf("Enter GPA: ");
    scanf("%f", &students[count].gpa);

    if(students[count].gpa < 0 || students[count].gpa > 4.0)
    {
        printf("Invalid GPA. GPA must be between 0 and 4.0.\n");
        return;
    }

    count++;
    printf("Student added successfully to local memory.\n");

    // Auto-save changes back to the CSV file
    saveToFile();
}

// Function to search student by roll number
int searchStudent(int rollNo)
{
    int i;

    for(i = 0; i < count; i++)
    {
        if(students[i].rollNo == rollNo)
        {
            return i;
        }
    }

    return -1;
}

void header()
{
    printf("\n======== Student Information ========\n");
    printf(" Student Name : Ubaid-ur-Rehman\n");
    printf(" Roll Number  : 2025-CPE-01\n");
    printf("=====================================\n");
}

// Function to read and parse CSV file data into the structure array
int loadFromFile()
{
    FILE *file = fopen(filePath, "r");
    if (file == NULL)
    {
        printf("Error: Could not open file '%s'.\n", filePath);
        return 0;
    }

    char line[150];
    count = 0;

    // Read the file line by line
    while (fgets(line, sizeof(line), file) && count < MAX)
    {
        // Remove trailing newline character if present
        line[strcspn(line, "\n")] = 0;

        // Skip blank lines
        if (strlen(line) == 0) continue;

        // Parse comma-separated fields: Name, Roll Number, GPA
        char *tokenName = strtok(line, ",");
        char *tokenRoll = strtok(NULL, ",");
        char *tokenGpa = strtok(NULL, ",");

        if (tokenName && tokenRoll && tokenGpa)
        {
            strncpy(students[count].name, tokenName, sizeof(students[count].name) - 1);
            students[count].name[sizeof(students[count].name) - 1] = '\0';
            students[count].rollNo = atoi(tokenRoll);
            students[count].gpa = atof(tokenGpa);
            count++;
        }
    }

    fclose(file);
    printf("Successfully loaded %d student(s) from file.\n", count);
    return 1;
}

// Function to save current structure array back to the CSV file
void saveToFile()
{
    FILE *file = fopen(filePath, "w");
    if (file == NULL)
    {
        printf("Error: Could not save changes to file.\n");
        return;
    }

    for (int i = 0; i < count; i++)
    {
        fprintf(file, "%s,%d,%.2f\n", students[i].name, students[i].rollNo, students[i].gpa);
    }

    fclose(file);
    printf("File updated successfully.\n");
}
