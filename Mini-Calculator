#include <stdio.h>

int main()
{
    int choice;
	char c_char;
    float num1, num2, result;
    
    const char *operation[5] = {
        "Addition",
        "Subtraction",
        "Multiplication",
        "Division",
        "Remainder"
    };

    printf("=== Simple Calculator ===\n");
    printf("Choose the operation:\n");
    printf("1 ---> Addition\n");
    printf("2 ---> Subtraction\n");
    printf("3 ---> Multiplication\n");
    printf("4 ---> Division\n");
    printf("5 ---> Remainder\n");
    
	for(c_char='Y';(c_char=='Y'||c_char=='y')&&(c_char!='N'||c_char!='n');)
	{
		printf("\nEnter your choice (1-5): ");
    	scanf("%d", &choice);
	    if(choice >= 1 && choice <= 5)
	    {
	        printf("\nYou have chosen: %s\n", operation[choice-1]);   
	        printf("Enter first number : ");
	        scanf("%f", &num1);
	        
	        printf("Enter second number: ");
	        scanf("%f", &num2);
	
	        switch(choice)//Switch-case is Employed as was demanded in the task.
	        {
	            case 1:
	                result = num1 + num2;
	                printf("Result = %.2f\n", result);
	                break;
	                
	            case 2:
	                result = num1 - num2;
	                printf("Result = %.2f\n", result);
	                break;
	                
	            case 3:
	                result = num1 * num2;
	                printf("Result = %.2f\n", result);
	                break;
	                
	            case 4:
	                if(num2 == 0)
	                    printf("Error: Division by zero is not allowed!\n");
	                else
	                {
	                    result = num1 / num2;
	                    printf("Result = %.2f\n", result);
	                }
	                break;
	                
	            case 5:
	                if(num2 == 0)
	                    printf("Error: Remainder with zero is not allowed!\n");
	                else
	                    printf("Result = %d\n", (int)num1 % (int)num2);
	                break;
	        }
	    for(;1==1;)
	    {
	    	 printf("\nDo you wish to calculate more? (Y/N):");
	         c_char=getch();
	        if((c_char=='Y'||c_char=='y')||(c_char=='N'||c_char=='n'))
				break;
	    	else
	    		printf("\nYou did not enter a valid response,try again");
		}
		}
	    else
	        printf("Invalid choice! Please enter number between 1 and 5.\n");
	}
	printf("\nThank you for using this program.");
    return 0;
}
